# ════════════════════════════════════════
#  GRINDX — Environment Variables
#  Copy this file to .env in Vercel Dashboard
# ════════════════════════════════════════

# ── FIREBASE ADMIN SDK ──
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ── ZAPUPI PAYMENT GATEWAY ──
ZAPUPI_API_KEY=your_zapupi_api_key
ZAPUPI_API_URL=https://api.zapupi.com
# Get API key from: panel.zapupi.com

# ── OTP EMAIL (Gmail SMTP) ──
SMTP_EMAIL=yourapp@gmail.com
SMTP_PASS=your_gmail_app_password
# Generate App Password: Google Account > Security > 2FA > App Passwords

# ── CORS ──
ALLOWED_ORIGIN=https://yourdomain.com
# Use * for testing, set your actual domain in production
